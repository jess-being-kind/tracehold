main() {
	parse_args "$@"
	info "Starting operator laptop bootstrap v$VERSION"
	print_change_plan
	install_packages
	setup_dirs
	setup_halcyon_color_tokens
	setup_system_theme
	setup_mplstyle
	setup_shell
	setup_terminator
	setup_vscode
	setup_vault
	setup_groups
	write_manifest
	print_next
}

main "$@"

