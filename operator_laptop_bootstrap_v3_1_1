#!/usr/bin/env bash
# operator_laptop_bootstrap_v3.1.1.sh
#
# Mint/Ubuntu-style operator laptop bootstrap.
#
# v3.1.1 intent:
#   - Keep the bootstrap focused on laptop/workspace/config/theme setup.
#   - Do not embed or write reusable sub-scripts/templates like plot.py, vecbin,
#     cleanup-downloads, or operator_*_template.*. Use the v3.0.0 standalone files.
#   - Use indented heredocs (<<-EOF / <<-'EOF') so generated-file sections stay
#     readable and foldable inside functions.
#   - Preserve Halcyon soot/amber/signal-blue/moss colors across shell, terminal,
#     matplotlib, Obsidian, GTK, and optional VS Code settings.
#   - Set the interactive prompt to: Vector-Halcyon |  <current path>:
#   - Configure Terminator with 80% transparency and a default 3-pane cockpit layout.
#   - Prefer JetBrainsMono Nerd Font ExtraThin at 11 pt wherever this script writes UI config.
#
# Examples:
#   bash operator_laptop_bootstrap_v3.1.1.sh
#   bash operator_laptop_bootstrap_v3.1.1.sh --apply --no-install
#   bash operator_laptop_bootstrap_v3.1.1.sh --apply --force --no-vscode-user

set -euo pipefail
IFS=$'\n\t'

# region S0: Metadata + default configuration
# ==============================================================================

