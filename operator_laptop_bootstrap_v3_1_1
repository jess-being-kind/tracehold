# region S1: Logging and safety helpers
# ==============================================================================

log()   { printf "\033[1;32m[OK]\033[0m %s\n" "$*"; }
info()  { printf "\033[1;34m[INFO]\033[0m %s\n" "$*"; }
warn()  { printf "\033[1;33m[WARN]\033[0m %s\n" "$*"; }
err()   { printf "\033[1;31m[ERR]\033[0m %s\n" "$*" >&2; }
debug() { if (( VERBOSE )); then printf "\033[0;36m[DEBUG]\033[0m %s\n" "$*"; fi; return 0; }

die() { err "$*"; exit 1; }
stamp() { date +"%Y%m%d_%H%M%S"; }
timestamp() { date +"%Y-%m-%dT%H:%M:%S%z"; }
have_cmd() { command -v "$1" >/dev/null 2>&1; }

run() {
	# Main side-effect gate. In dry-run mode, print instead of executing.
	if (( APPLY )); then
		debug "RUN: $*"
		"$@"
	else
		printf '[DRY RUN] '
		printf '%q ' "$@"
		printf '\n'
	fi
}

run_optional() {
	# Same as run(), but failures are warnings. Useful for desktop settings.
	if (( APPLY )); then
		debug "TRY: $*"
		"$@" || warn "Optional command failed or is unsupported: $*"
	else
		printf '[DRY RUN optional] '
		printf '%q ' "$@"
		printf '\n'
	fi
}

ensure_dir() {
	local dir="${1:?ensure_dir requires a directory}"
	run mkdir -p "$dir"
}

backup_if_exists() {
	local path="${1:?backup_if_exists requires a path}"
	if [[ -e "$path" || -L "$path" ]]; then
		local backup="${path}.bak.$(stamp)"
		warn "Backing up existing path: $path -> $backup"
		run cp -a "$path" "$backup"
	fi
}

write_file() {
	# Managed-file writer:
	#   - skip existing files unless --force is set
	#   - backup before replacement when --force is set
	local path="${1:?write_file requires a path}"
	local content="${2-}"

	ensure_dir "$(dirname "$path")"

	if [[ -e "$path" && "$FORCE" -ne 1 ]]; then
		warn "Exists, skipping: $path  Use --force to replace."
		return 0
	fi

	if [[ -e "$path" ]]; then
		backup_if_exists "$path"
	fi

	if (( APPLY )); then
		printf '%s' "$content" > "$path"
		log "Wrote $path"
	else
		echo "[DRY RUN] write $path"
	fi
}

write_file_stream() {
	# Use with indented heredocs:
	#   write_file_stream "$path" <<-EOF
	#       content
	#   EOF
	local path="${1:?write_file_stream requires a path}"
	local content
	content="$(cat)"
	write_file "$path" "$content"$'\n'
}

append_once() {
	# Append exactly one source/config line to an existing file.
	local path="${1:?append_once requires a path}"
	local marker="${2:?append_once requires a marker}"
	local line="${3:?append_once requires a line}"

	ensure_dir "$(dirname "$path")"

	if [[ -f "$path" ]] && grep -Fq "$marker" "$path"; then
		log "$path already contains: $marker"
		return 0
	fi

	if (( APPLY )); then
		printf '\n%s\n%s\n' "$marker" "$line" >> "$path"
		log "Appended to $path: $marker"
	else
		echo "[DRY RUN] append to $path: $marker"
	fi
}

