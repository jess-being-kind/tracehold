setup_shell() {
	info "Creating shell helpers"

	write_file_stream "$HOME/.operator_aliases" <<-'EOF'
	# ~/.operator_aliases
	# Generated by operator_laptop_bootstrap.
	# Purpose: interactive shell behavior, prompt, aliases, and Halcyon colors.
	# Safe to edit, but rerunning bootstrap with --force will back it up.

	# region S0. Guardrails / paths
	[[ -f "$HOME/.config/halcyon/colors.env" ]] && source "$HOME/.config/halcyon/colors.env"
	stty -ixon 2>/dev/null || true

	export VEC_ROOT="${VEC_ROOT:-$HOME/Vec}"
	export ENGINEERING_DIR="${ENGINEERING_DIR:-$VEC_ROOT/Engineering}"
	export VAULT_DIR="${VAULT_DIR:-$VEC_ROOT/Vaults/Work}"
	export HALCYON_FONT_FAMILY="${HALCYON_FONT_FAMILY:-JetBrainsMono Nerd Font ExtraThin}"
	export HALCYON_FONT_SIZE="${HALCYON_FONT_SIZE:-11}"
	export HALCYON_FONT_PANGO="${HALCYON_FONT_PANGO:-${HALCYON_FONT_FAMILY} ${HALCYON_FONT_SIZE}}"

	path_prepend() {
		local dir="${1:?path_prepend requires a directory}"
		[[ -d "$dir" ]] || return 0
		case ":$PATH:" in
			*":$dir:"*) ;;
			*) export PATH="$dir:$PATH" ;;
		esac
	}

	path_prepend "$HOME/.local/bin"
	path_prepend "$HOME/bin"
	path_prepend "$ENGINEERING_DIR/bin"
	path_prepend "$ENGINEERING_DIR/scripts"

	export EDITOR="${EDITOR:-vim}"
	export VISUAL="${VISUAL:-$EDITOR}"
	export PAGER="${PAGER:-less}"
	export LESS="${LESS:--FRX}"
	export PYTHONUNBUFFERED=1
	export PYTHONDONTWRITEBYTECODE=1
	# endregion S0

	# region S1. History
	export HISTSIZE=20000
	export HISTFILESIZE=50000
	export HISTCONTROL=ignoreboth:erasedups
	export HISTTIMEFORMAT='%F %T  '
	shopt -s histappend 2>/dev/null || true
	__halcyon_history_sync='history -a; history -n'
	if [[ -n "${PROMPT_COMMAND:-}" ]]; then
		case ";${PROMPT_COMMAND};" in
			*";${__halcyon_history_sync};"*) ;;
			*) PROMPT_COMMAND="${__halcyon_history_sync}; ${PROMPT_COMMAND}" ;;
		esac
	else
		PROMPT_COMMAND="${__halcyon_history_sync}"
	fi
	unset __halcyon_history_sync
	# endregion S1

