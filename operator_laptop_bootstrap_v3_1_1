setup_groups() {
	info "Checking useful hardware groups"
	local groups=(dialout plugdev i2c)
	local g
	for g in "${groups[@]}"; do
		if getent group "$g" >/dev/null 2>&1; then
			run_optional sudo usermod -aG "$g" "$USER"
		else
			debug "Group not present: $g"
		fi
	done
	warn "Group membership changes may require log out/in."
}

