	append_once "$HOME/.bashrc" "# Halcyon color tokens" '[[ -f "$HOME/.config/halcyon/colors.env" ]] && source "$HOME/.config/halcyon/colors.env"'

	write_file_stream "$HOME/.inputrc" <<-'EOF'
