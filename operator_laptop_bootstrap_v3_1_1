	vec_root=$VEC_ROOT
	engineering_dir=$ENGINEERING_DIR
	vault_dir=$VAULT_DIR
	local_bin=$LOCAL_BIN
	halcyon_config_dir=$HALCYON_CONFIG_DIR
	wrote_embedded_subscripts=false
	notes=Version 3.1.0 intentionally does not generate plot.py/templates/helper scripts.
	EOF
}

print_next() {
	cat <<-EOF

	===============================================================================
	Bootstrap v$VERSION complete
	===============================================================================

	Next steps:
	  source ~/.bashrc
	  terminator

	Terminator should open fullscreen with three panes:
	  left = Navigation, right top = Execution, right bottom = General
	  transparency = 80%, font = $HALCYON_FONT_PANGO

	Useful commands after sourcing ~/.bashrc:
	  cd <dir>             # change dir, then list contents with ls -lrt
	  eng                  # jump to engineering workspace
	  proj                 # active projects
	  mkproj <name>        # create a structured project
	  todaylog             # open today's log folder
	  fieldnote <name>     # create a quick field note

	Standalone scripts:
	  v3.1.1 does not write plot.py/templates/helper scripts.
	  Put your v3.0.0 standalone files in:
	    $ENGINEERING_DIR/scripts
	  They will be available automatically after ~/.operator_aliases adds that path.

	Obsidian:
	  Open folder as vault -> $VAULT_DIR
	  Enable CSS snippets -> halcyon-dark
	  Confirm Templates folder = 80-Templates
	  Confirm Daily Notes folder = 10-Daily

	Optional Git identity:
	  git config --global user.name "V Halcyon"
	  git config --global user.email "<work-or-personal-email>"
	  git config --global init.defaultBranch main

	EOF

	if (( ! APPLY )); then
		echo "Dry run only. Apply with: bash $SCRIPT_NAME --apply"
	fi
}

cleanup() {
	local status=$?
	if (( status != 0 )); then
		warn "Script exited with status $status"
	fi
}
trap cleanup EXIT

