ENGINEERING_CUSTOM=0

# Workspace roots. Folder names stay normal; the top-level namespace is ~/Vec.
VEC_ROOT="${VEC_ROOT:-$HOME/Vec}"
VAULT_DIR="${VAULT_DIR:-$VEC_ROOT/Vaults/Work}"
