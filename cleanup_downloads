#!/usr/bin/env bash
# cleanup-downloads
#
# Purpose:
#   Generic Bash template for engineering/operator automation.
#
# Good for:
#   - setup scripts
#   - hardware runner scripts
#   - data collection wrappers
#   - file organization
#   - repeatable test commands
#
# Best-practice notes:
#   - Keep functions small and testable.
#   - Put side effects behind run_cmd.
#   - Use --dry-run by default for risky operations.
#   - Guard main so tests can source this file without running it.

set -euo pipefail

VERSION="3.0.0"
IFS=$'\n\t'

SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUN_ID="$(date +"%Y%m%d_%H%M%S")"

AUTHOR="V Halcyon"
VERSION="2.0.1"

APPLY=0
VERBOSE=0
FORCE=0

PDF="$HOME/Downloads/pdf/"
IMAGES="$HOME/Downloads/images/"
SCRIPTS="$HOME/Downloads/scripts/"
ARCHIVE="$HOME/Downloads/archive/"
MISC="$HOME/Downloads/misc"

log()  { printf "\033[1;32m[OK]\033[0m %s\n" "$*"; }
info() { printf "\033[1;34m[INFO]\033[0m %s\n" "$*"; }
warn() { printf "\033[1;33m[WARN]\033[0m %s\n" "$*"; }
err()  { printf "\033[1;31m[ERR]\033[0m %s\n" "$*" >&2; }
debug() {
    if (( VERBOSE )); then
        printf "\033[0;36m[DEBUG]\033[0m %s\n" "$*"
    fi
    return 0
}

die() { err "$*"; exit 1; }

timestamp() { date +"%Y-%m-%dT%H:%M:%S%z"; }

require_command() {
    local cmd="$1"
    command -v "$cmd" >/dev/null 2>&1 || die "Missing required command: $cmd"
}

run_cmd() {
    if (( APPLY )); then
        debug "RUN: $*"
        "$@"
    else
        printf "[DRY RUN] "
        printf "%q " "$@"
        printf "\n"
    fi
}

ensure_dir() {
    local dir="$1"
    run_cmd mkdir -p "$dir"
}

backup_if_exists() {
    local path="$1"
    if [[ -e "$path" ]]; then
        local backup="${path}.bak.${RUN_ID}"
        warn "Backing up existing path: $path -> $backup"
        run_cmd cp -a "$path" "$backup"
    fi
}

write_file() {
    local path="$1"
    local content="$2"

    if [[ -e "$path" && "$FORCE" -ne 1 ]]; then
        warn "File exists, skipping: $path  Use --force to replace."
        return 0
    fi

    ensure_dir "$(dirname "$path")"

    if [[ -e "$path" ]]; then
        backup_if_exists "$path"
    fi

    if (( APPLY )); then
        printf "%s" "$content" > "$path"
        log "Wrote $path"
    else
        echo "[DRY RUN] write $path"
    fi
}

assert_file_exists() {
    local path="$1"
    [[ -f "$path" ]] || die "Expected file does not exist: $path"
}

assert_dir_exists() {
    local path="$1"
    [[ -d "$path" ]] || die "Expected directory does not exist: $path"
}

is_positive_integer() { [[ "${1:-}" =~ ^[1-9][0-9]*$ ]]; }

move_matches() {
    local dest="$1"
    shift

    local files=( "$@" )

    if ((${#files[@]} == 0)); then
        debug "No files matched for $dest"
        return 0
    fi

    run_cmd mv "${files[@]}" "$dest"
}

cleanup() {
    local status=$?
    if (( status != 0 )); then
        warn "Script exited with status $status"
    fi
}
trap cleanup EXIT

usage() {
    cat <<USAGE
Usage: $SCRIPT_NAME [options]

This script automatically organizes Downloads directory

Options:
  --apply                 Actually perform actions. Default is dry-run.
  --dry-run               Print actions without changing anything.
  --force                 Replace generated files after backing them up.
  -v, --verbose           Enable debug logging.
  -h, --help              Show this help.

Examples:
  $SCRIPT_NAME
  $SCRIPT_NAME --apply
USAGE
}

parse_args() {
    while (($#)); do
        case "$1" in
            --apply) APPLY=1 ;;
            --dry-run) APPLY=0 ;;
            --force) FORCE=1 ;;
            -v|--verbose) VERBOSE=1 ;;
            -h|--help) usage; exit 0 ;;
            *) die "Unknown argument: $1" ;;
        esac
        shift
    done
}

make_run_manifest() {
    cat <<MANIFEST
run_id=$RUN_ID
timestamp=$(timestamp)
script=$SCRIPT_NAME
script_dir=$SCRIPT_DIR
apply=$APPLY
version=$VERSION
author=$AUTHOR
MANIFEST
}

run_workflow() {
    info "Starting workflow"
    info "Run ID: $RUN_ID"

    ensure_dir "$HOME/Downloads/"
    ensure_dir "$PDF"
    ensure_dir "$IMAGES"
    ensure_dir "$SCRIPTS"
    ensure_dir "$ARCHIVE"
    ensure_dir "$MISC"
    debug "Wrote sub-directories"

    local manifest_path="$HOME/Engineering/logs/run_manifest_cleanup_dir_${RUN_ID}.txt"
    write_file "$manifest_path" "$(make_run_manifest)"

    shopt -s nullglob

    cd "$HOME/Downloads" || die "Could not cd to Downloads"

    move_matches "$PDF" ./*.[pP][dD][fF]

    move_matches "$IMAGES" \
        ./*.[pP][nN][gG] \
        ./*.[jJ][pP][gG] \
        ./*.[jJ][pP][eE][gG] \
        ./*.[gG][iI][fF] \
        ./*.[wW][eE][bB][pP] \
        ./*.[sS][vV][gG] \
        ./*.[hH][eE][iI][cC]

    move_matches "$SCRIPTS" \
        ./*.[sS][hH] \
        ./*.[pP][yY] \
        ./*.[mM][aA][tT]

    move_matches "$ARCHIVE" \
        ./*.[zZ][iI][pP] \
        ./*.[tT][aA][rR] \
        ./*.[gG][zZ] \
        ./*.[bB][aA][kK]


    info "Clean Downloads directory workflow complete"
}

main() {
    parse_args "$@"
    run_workflow
}

# Main guard: makes this file sourceable for tests.
if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
