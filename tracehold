main() {

    install_runtime

    parse_args "$@"

    if (( SCRIPT[SELF_TEST] )); then
        run_self_test
    else
        validate_config
        run_workflow
    fi
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi

