# --- CLI helpers -------------------------------------------------------------

set_cli_value() {
    local option="$1"
    local destination_name="$2"
    local was_set_name="$3"
    local value="${4-}"
    local -n destination="$destination_name"
    local -n was_set="$was_set_name"

    [[ -n "$value" ]] || hardstop "Missing value for ${option}" "$EX_IOERR"
    [[ "$value" != -* ]] || hardstop "Missing value for ${option}; found option '${value}' instead" "$EX_IOERR"

    destination="$value"
    was_set=1
}

collect_cli_values() {
    local option="$1"
    local destination_name="$2"
    local was_set_name="$3"
    local -n destination="$destination_name"
    local -n was_set="$was_set_name"
    local count=0

    shift 3

    while (( $# > 0 )) && [[ "$1" != -* ]]; do
        destination+=("$1")
        (( count += 1 ))
        shift
    done

    (( count > 0 )) || hardstop "${option} requires at least one value" "$EX_IOERR"

    was_set=1
    CLI_VALUES_CONSUMED="$count"
}

select_command() {
    local command="$1"
    local selected_count

    selected_count=$((
        COMMANDS[NEW]
        + COMMANDS[ADD]
        + COMMANDS[COLLECT]
        + COMMANDS[VERIFY]
        + COMMANDS[BUNDLE]
    ))

    (( selected_count == 0 )) || hardstop "Only one command may be selected" "$EX_USAGE"

    case "$command" in
        new)     COMMANDS[NEW]=1 ;;
        add)     COMMANDS[ADD]=1 ;;
        collect) COMMANDS[COLLECT]=1 ;;
        verify)  COMMANDS[VERIFY]=1 ;;
        bundle)  COMMANDS[BUNDLE]=1 ;;
        *)       hardstop "Unknown command: ${command}" "$EX_IOERR" ;;
    esac

    debug "Command '${command}' selected"
}

sync_variadic_inputs() {
    if (( WAS_SET[ASSET] )); then
        INPUT[ASSET]="$(join_by ', ' "${ASSETS[@]}")"
    fi

    if (( WAS_SET[SITE] )); then
        INPUT[SITE]="$(join_by ', ' "${SITES[@]}")"
    fi

    if (( WAS_SET[OWNER] )); then
        INPUT[OWNER]="$(join_by ', ' "${OWNERS[@]}")"
    fi

    if (( WAS_SET[RECENT_CHANGE] )); then
        INPUT[RECENT_CHANGE]="$(join_by '; ' "${RECENT_CHANGES[@]}")"
    fi
}

# --- Argument parsing --------------------------------------------------------

parse_args() {
    local CLI_VALUES_CONSUMED=0

    while (( $# > 0 )); do
        case "$1" in
            # Case description
            --title)
                set_cli_value "$1" "INPUT[TITLE]" "WAS_SET[TITLE]" "${2-}"
                shift 2
                ;;
            --description)
                set_cli_value "$1" "INPUT[DESCRIPTION]" "WAS_SET[DESCRIPTION]" "${2-}"
                shift 2
                ;;
            --asset)
                shift
                collect_cli_values "--asset" ASSETS "WAS_SET[ASSET]" "$@"
                shift "$CLI_VALUES_CONSUMED"
                ;;
            --severity)
                set_cli_value "$1" "INPUT[SEVERITY]" "WAS_SET[SEVERITY]" "${2-}"
                shift 2
                ;;
            --site)
                shift
                collect_cli_values "--site" SITES "WAS_SET[SITE]" "$@"
                shift "$CLI_VALUES_CONSUMED"
                ;;

            # Ownership and timeline
            --reported-by)
                set_cli_value "$1" "INPUT[REPORTED_BY]" "WAS_SET[REPORTED_BY]" "${2-}"
                shift 2
                ;;
            --owner)
                shift
                collect_cli_values "--owner" OWNERS "WAS_SET[OWNER]" "$@"
                shift "$CLI_VALUES_CONSUMED"
                ;;
            --first-observed)
                set_cli_value "$1" "INPUT[FIRST_OBSERVED]" "WAS_SET[FIRST_OBSERVED]" "${2-}"
                shift 2
                ;;
            --last-observed)
                set_cli_value "$1" "INPUT[LAST_OBSERVED]" "WAS_SET[LAST_OBSERVED]" "${2-}"
                shift 2
                ;;

            # Triage state
            --operational-impact)
                set_cli_value "$1" "INPUT[OPERATIONAL_IMPACT]" "WAS_SET[OPERATIONAL_IMPACT]" "${2-}"
                shift 2
                ;;
            --affected-scope)
                set_cli_value "$1" "INPUT[AFFECTED_SCOPE]" "WAS_SET[AFFECTED_SCOPE]" "${2-}"
                shift 2
                ;;
            --recent-change)
                shift
                collect_cli_values "--recent-change" RECENT_CHANGES "WAS_SET[RECENT_CHANGE]" "$@"
                shift "$CLI_VALUES_CONSUMED"
                ;;
            --status)
                set_cli_value "$1" "INPUT[STATUS]" "WAS_SET[STATUS]" "${2-}"
                shift 2
                ;;
            --repro-status)
                set_cli_value "$1" "INPUT[REPRO_STATUS]" "WAS_SET[REPRO_STATUS]" "${2-}"
                shift 2
                ;;
            --containment-status)
                set_cli_value "$1" "INPUT[CONTAINMENT_STATUS]" "WAS_SET[CONTAINMENT_STATUS]" "${2-}"
                shift 2
                ;;
            --triage-confidence)
                set_cli_value "$1" "INPUT[TRIAGE_CONFIDENCE]" "WAS_SET[TRIAGE_CONFIDENCE]" "${2-}"
                shift 2
                ;;

            # Case and evidence selection
            --profile)
                set_cli_value "$1" "INPUT[PROFILE]" "WAS_SET[PROFILE]" "${2-}"
                shift 2
                ;;
            --case)
                set_cli_value "$1" "INPUT[CASE]" "WAS_SET[CASE]" "${2-}"
                shift 2
                ;;
            --file)
                set_cli_value "$1" "INPUT[FILE]" "WAS_SET[FILE]" "${2-}"
                shift 2
                ;;
            --type)
                set_cli_value "$1" "INPUT[TYPE]" "WAS_SET[TYPE]" "${2-}"
                shift 2
                ;;
            --output-dir)
                set_cli_value "$1" "INPUT[OUTPUT_DIR]" "WAS_SET[OUTPUT_DIR]" "${2-}"
                shift 2
                ;;

            # Execution behavior
            --apply)
                SCRIPT[APPLY]=1
                shift
                ;;
            --dry-run|--no-load-run)
                SCRIPT[APPLY]=0
                shift
                ;;
            --force)
                SCRIPT[FORCE]=1
                shift
                ;;
            -v|--verbose)
                SCRIPT[VERBOSE]=1
                shift
                ;;
            --self-test)
                SCRIPT[SELF_TEST]=1
                shift
                ;;
            --version)
                printf '%s\n' "$VERSION"
                exit 0
                ;;
            -h|--help)
                usage
                exit 0
                ;;

            # Commands
            new|add|collect|verify|bundle)
                select_command "$1"
                shift
                ;;

            --)
                shift
                (( $# == 0 )) || hardstop "Unexpected positional argument after --: $1" "$EX_IOERR"
                break
                ;;
            -*)
                hardstop "Unknown option: $1" "$EX_USAGE"
                ;;
            *)
                hardstop "Unknown argument: $1" "$EX_IOERR"
                ;;
        esac
    done

    sync_variadic_inputs
}

# --- Configuration validation ------------------------------------------------

validate_config() {
    local command_count

    debug "running validate_config..."

    command_count=$((
        COMMANDS[NEW]
        + COMMANDS[ADD]
        + COMMANDS[COLLECT]
        + COMMANDS[VERIFY]
        + COMMANDS[BUNDLE]
    ))

    (( command_count == 1 )) || hardstop "Select exactly one command: new, add, collect, verify, or bundle" "$EX_USAGE"

	# validate 'new' workflow
    if (( COMMANDS[NEW] )); then
        (( WAS_SET[CASE] == 0 )) || hardstop "--case cannot be used with the 'new' command" "$EX_USAGE"
        (( WAS_SET[TITLE] )) || hardstop "Input --title required"  "$EX_USAGE"
        (( WAS_SET[DESCRIPTION] )) || hardstop "Input --description required" "$EX_USAGE"
        (( WAS_SET[SEVERITY] )) || hardstop "Input --severity required" "$EX_USAGE"
        (( WAS_SET[ASSET] )) || hardstop "Input --asset required" "$EX_USAGE"

        [[ "${INPUT[SEVERITY]}" =~ ^P[0-4]$ ]] \
            || hardstop "Invalid --severity '${INPUT[SEVERITY]}'; expected P0 through P4" "$EX_USAGE"

        INPUT[CASE]="${CASE_PREFIX}_${RUN_ID}_${INPUT[TITLE]}"
		debug "Generated Case-ID: ${INPUT[CASE]}"
        return 0
    fi

	# all other commands require case-id and NOT title
    (( WAS_SET[TITLE] == 0 )) || hardstop "--title is only valid with the 'new' command" "$EX_USAGE"
    (( WAS_SET[CASE] )) || hardstop "Input --case required" "$EX_USAGE"

	# checking whether case-id exists
    [[ -d "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}" ]] \
        || hardstop "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]} does not exist" "$EX_DATAERR"

	# validate 'add' workflow
    if (( COMMANDS[ADD] )); then
        (( WAS_SET[FILE] )) || hardstop "Input --file required" "$EX_USAGE"
        [[ -f "${INPUT[FILE]}" ]] || hardstop "${INPUT[FILE]} is not a regular file" "$EX_DATAERR"
        (( WAS_SET[TYPE] )) || hardstop "Input --type required" "$EX_USAGE"

        case "${INPUT[TYPE]}" in
            raw|photo|log|other) return 0;;
            *) hardstop "Invalid --type '${INPUT[TYPE]}'; expected raw, photo, log, or other" "$EX_IOERR" ;;
        esac
    fi

	# validate 'collect' workflow
    if (( COMMANDS[COLLECT] )) && (( WAS_SET[PROFILE] == 0 )); then
        debug "No --profile supplied; using '${INPUT[PROFILE]}'"
    fi

	# validate 'verify' workflow
    if (( COMMANDS[VERIFY] )); then
        debug "Running validate_config VERIFY"
    fi

	# validate 'bundle' workflow
    if (( COMMANDS[BUNDLE] )); then
        debug "Running validate_config BUNDLE"
    fi
}

