# --- Run manifest ------------------------------------------------------------

make_run_manifest() {
    debug "running make_run_manifest"

    local path="${1:?make_run_manifest requires an output path}"
    local generated_at
    local manifest

    require_command jq

    generated_at="$(timestamp)"

    manifest="$(
        jq -n \
            --arg schema_version       "1.0" \
            --arg manifest_type        "tracehold.run_manifest" \
            --arg tracehold_version    "$VERSION" \
            --arg author               "$AUTHOR" \
            --arg script_name          "$SCRIPT_NAME" \
            --arg script_path          "$SCRIPT_PATH" \
            --arg script_dir           "$SCRIPT_DIR" \
            --arg run_id               "$RUN_ID" \
            --arg generated_at_utc     "$generated_at" \
            --arg working_directory    "$(pwd -P)" \
            --arg profile              "${INPUT[PROFILE]}" \
            --arg output_dir           "${INPUT[OUTPUT_DIR]}" \
            --arg title                "${INPUT[TITLE]}" \
            --arg description          "${INPUT[DESCRIPTION]}" \
            --arg asset                "${INPUT[ASSET]}" \
            --arg severity             "${INPUT[SEVERITY]}" \
            --arg site                 "${INPUT[SITE]}" \
            --arg reported_by          "${INPUT[REPORTED_BY]}" \
            --arg owner                "${INPUT[OWNER]}" \
            --arg first_observed       "${INPUT[FIRST_OBSERVED]}" \
            --arg last_observed        "${INPUT[LAST_OBSERVED]}" \
            --arg operational_impact   "${INPUT[OPERATIONAL_IMPACT]}" \
            --arg affected_scope       "${INPUT[AFFECTED_SCOPE]}" \
            --arg recent_change        "${INPUT[RECENT_CHANGE]}" \
            --arg status               "${INPUT[STATUS]}" \
            --arg repro_status         "${INPUT[REPRO_STATUS]}" \
            --arg containment_status   "${INPUT[CONTAINMENT_STATUS]}" \
            --arg triage_confidence    "${INPUT[TRIAGE_CONFIDENCE]}" \
            --arg case_id              "${INPUT[CASE]}" \
            --arg file                 "${INPUT[FILE]}" \
            --arg evidence_type        "${INPUT[TYPE]}" \
            --argjson process_id       "$$" \
            --argjson bash_process_id  "$BASHPID" \
            --argjson apply            "${SCRIPT[APPLY]}" \
            --argjson force            "${SCRIPT[FORCE]}" \
            --argjson verbose          "${SCRIPT[VERBOSE]}" \
            --argjson self_test        "${SCRIPT[SELF_TEST]}" \
            --argjson title_set               "${WAS_SET[TITLE]}" \
            --argjson description_set         "${WAS_SET[DESCRIPTION]}" \
            --argjson asset_set               "${WAS_SET[ASSET]}" \
            --argjson severity_set            "${WAS_SET[SEVERITY]}" \
            --argjson site_set                "${WAS_SET[SITE]}" \
            --argjson reported_by_set         "${WAS_SET[REPORTED_BY]}" \
            --argjson owner_set               "${WAS_SET[OWNER]}" \
            --argjson first_observed_set      "${WAS_SET[FIRST_OBSERVED]}" \
            --argjson last_observed_set       "${WAS_SET[LAST_OBSERVED]}" \
            --argjson operational_impact_set  "${WAS_SET[OPERATIONAL_IMPACT]}" \
            --argjson affected_scope_set      "${WAS_SET[AFFECTED_SCOPE]}" \
            --argjson recent_change_set       "${WAS_SET[RECENT_CHANGE]}" \
            --argjson status_set              "${WAS_SET[STATUS]}" \
            --argjson repro_status_set        "${WAS_SET[REPRO_STATUS]}" \
            --argjson containment_status_set  "${WAS_SET[CONTAINMENT_STATUS]}" \
            --argjson triage_confidence_set   "${WAS_SET[TRIAGE_CONFIDENCE]}" \
            --argjson profile_set             "${WAS_SET[PROFILE]}" \
            --argjson case_set                "${WAS_SET[CASE]}" \
            --argjson file_set                "${WAS_SET[FILE]}" \
            --argjson type_set                "${WAS_SET[TYPE]}" \
            --argjson output_dir_set          "${WAS_SET[OUTPUT_DIR]}" \
            --argjson command_new             "${COMMANDS[NEW]}" \
            --argjson command_add             "${COMMANDS[ADD]}" \
            --argjson command_collect         "${COMMANDS[COLLECT]}" \
            --argjson command_verify          "${COMMANDS[VERIFY]}" \
            --argjson command_bundle          "${COMMANDS[BUNDLE]}" \
            '
            {
                new:     ($command_new == 1),
                add:     ($command_add == 1),
                collect: ($command_collect == 1),
                verify:  ($command_verify == 1),
                bundle:  ($command_bundle == 1)
            } as $command_flags

            | [
                $command_flags
                | to_entries[]
                | select(.value == true)
                | .key
            ] as $active_commands

            | {
                schema_version: $schema_version,
                manifest_type: $manifest_type,

                metadata: {
                    tracehold_version: $tracehold_version,
                    author: $author,
                    script: {
                        name: $script_name,
                        path: $script_path,
                        directory: $script_dir
                    }
                },

                execution: {
                    run_id: $run_id,
                    generated_at_utc: $generated_at_utc,
                    working_directory: $working_directory,
                    process_id: $process_id,
                    bash_process_id: $bash_process_id,
                    mode: (
                        if $apply == 1
                        then "apply"
                        else "dry_run"
                        end
                    ),
                    flags: {
                        apply: ($apply == 1),
                        force: ($force == 1),
                        verbose: ($verbose == 1),
                        self_test: ($self_test == 1)
                    }
                },

                commands: {
                    flags: $command_flags,
                    active: $active_commands,
                    active_count: ($active_commands | length)
                },

                inputs: {
                    case_description: {
                        title: $title,
                        description: $description,
                        asset: $asset,
                        severity: $severity,
                        site: $site
                    },

                    ownership_and_timeline: {
                        reported_by: $reported_by,
                        owner: $owner,
                        first_observed: $first_observed,
                        last_observed: $last_observed
                    },

                    triage_state: {
                        operational_impact: $operational_impact,
                        affected_scope: $affected_scope,
                        recent_change: $recent_change,
                        status: $status,
                        reproduction_status: $repro_status,
                        containment_status: $containment_status,
                        triage_confidence: $triage_confidence
                    },

                    case_and_evidence: {
                        profile: $profile,
                        case_id: $case_id,
                        file: $file,
                        evidence_type: $evidence_type,
                        output_directory: $output_dir
                    }
                },

                input_provenance: {
                    was_set: {
                        title: ($title_set == 1),
                        description: ($description_set == 1),
                        asset: ($asset_set == 1),
                        severity: ($severity_set == 1),
                        site: ($site_set == 1),

                        reported_by: ($reported_by_set == 1),
                        owner: ($owner_set == 1),
                        first_observed: ($first_observed_set == 1),
                        last_observed: ($last_observed_set == 1),

                        operational_impact: ($operational_impact_set == 1),
                        affected_scope: ($affected_scope_set == 1),
                        recent_change: ($recent_change_set == 1),
                        status: ($status_set == 1),
                        reproduction_status: ($repro_status_set == 1),
                        containment_status: ($containment_status_set == 1),
                        triage_confidence: ($triage_confidence_set == 1),

                        profile: ($profile_set == 1),
                        case_id: ($case_set == 1),
                        file: ($file_set == 1),
                        evidence_type: ($type_set == 1),
                        output_directory: ($output_dir_set == 1)
                    }
                }
            }
            '
    )" || hardstop "Failed to construct run manifest" "$EX_CANTCREAT"

    write_file "$path" "${manifest}"$'\n'
}

# --- Case manifest -----------------------------------------------------------

make_case_manifest() {
    debug "running make_case_manifest"
    local path="$1"

    write_file_stream "$path" <<-CASE_MANIFEST
	case_directory=${INPUT[CASE]}
	assets=${INPUT[ASSET]}
	severity=${INPUT[SEVERITY]}
	site=${INPUT[SITE]:-""}
	files_added=${INPUT[FILE]}
	files_type=${INPUT[TYPE]}
	profile=${INPUT[PROFILE]}
	CASE_MANIFEST
}

# --- Environment snapshot ----------------------------------------------------

environment_check() {
    debug "running environment_check"
    local path="$1"

    write_file_stream "$path" <<-ENVIRONMENT_CHECK
	bash_version=$(bash --version)
	UTC_run_time=$(timestamp)
	user=$(uname -a)
	uptime=$(uptime)
	memory=$(free -h)
	disk=$(df -h)
	interfaces=$(lsusb)
	system_specs=$(lspci)
	dmesg_err=$(dmesg --level err)
