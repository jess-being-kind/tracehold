# --- S9.1 Shared-schema validation ---------------------------------------

validate_command_contract() {
    local command_key option_key
    local -a required_options=() allowed_options=()

    command_key="$(active_command_key)" \
        || hardstop "Internal state error: no active command" "$EX_SOFTWARE"

    IFS=' ' read -r -a required_options <<< "${COMMAND_REQUIRED[$command_key]}"
    IFS=' ' read -r -a allowed_options <<< "${COMMAND_ALLOWED[$command_key]}"

    for option_key in "${required_options[@]}"; do
        option_is_set "$option_key" \
            || hardstop \
                "Input ${OPTION_CLI[$option_key]} required for '${COMMAND_NAME[$command_key]}'" \
                "$EX_USAGE"
    done

    for option_key in "${OPTION_KEYS[@]}"; do
        option_is_set "$option_key" || continue

        word_in_schema_list "$option_key" "${COMMAND_ALLOWED[$command_key]}" \
            || hardstop \
                "${OPTION_CLI[$option_key]} is not valid with the '${COMMAND_NAME[$command_key]}' command" \
                "$EX_USAGE"
    done
}

validate_enum_options() {
    local option_key allowed value item matched
    local destination_name
    local -a allowed_values=()

    for option_key in "${OPTION_KEYS[@]}"; do
        [[ "${OPTION_KIND[$option_key]}" == "enum" ]] || continue
        option_is_set "$option_key" || continue

        destination_name="${OPTION_DEST[$option_key]}"
        local -n value_ref="$destination_name"
        value="$value_ref"
        allowed="${OPTION_ENUM[$option_key]}"
        matched=0
        IFS=' ' read -r -a allowed_values <<< "$allowed"

        for item in "${allowed_values[@]}"; do
            if [[ "$value" == "$item" ]]; then
                matched=1
                break
            fi
        done

        (( matched )) \
            || hardstop \
                "Invalid ${OPTION_CLI[$option_key]} '${value}'; expected one of: ${allowed}" \
                "$EX_USAGE"
    done
}

# --- S9.2 Command-specific and persistent-state validation ---------------

validate_case_prefix() {
    # Case IDs depend on a compact, stable prefix. Validate it before using it
    # to build or evaluate any regular expression.
    [[ "${CASE_PREFIX}" == [[:alnum:]][[:alnum:]] ]] \
        || hardstop "Invalid CASE_PREFIX -- must be 2-char alphanumeric" "$EX_USAGE"
}

validate_new_case_state() {
    # The shared schema has already checked required/allowed options and enums.
    # This layer validates the title syntax and resolved paths specific to NEW.
    [[ "${INPUT[TITLE]}" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] \
        || hardstop "Title must contain only letters, numbers, dots, underscores, and hyphens" "$EX_USAGE"

    [[ -n "$CASE_DIR" && -n "$MANIFEST_DIR" ]] \
        || hardstop "Internal state resolution failed for new case" "$EX_SOFTWARE"

    log "Generated Case-ID: ${INPUT[CASE]}"
}

validate_existing_case_id() {
    local case_regex
    local regex_status

    # Existing-case commands must point at a Tracehold-shaped directory name.
    # Calendar validity is intentionally out of scope; this checks structure.
    case_regex="^${CASE_PREFIX}_[0-9]{8}_[0-9]{6}_UTC_[A-Za-z0-9_.-]*$"

    if [[ "${INPUT[CASE]}" =~ $case_regex ]]; then
        debug "Case-ID validated: <${INPUT[CASE]}>"
        return 0
    else
        # Capture the regex engine status before another command overwrites it.
        regex_status=$?
    fi

    if (( regex_status == 2 )); then
        hardstop \
            "Internal error: invalid Case-ID regex <$case_regex>" \
            "$EX_SOFTWARE"
    fi

    hardstop \
        "Invalid Case-ID <${INPUT[CASE]}>; expected ${CASE_PREFIX}_YYYYMMDD_HHMMSS_UTC_title" \
        "$EX_USAGE"
}

load_existing_case_state() {
    # Resolve and verify the persistent state shared by ADD/COLLECT/VERIFY/BUNDLE.
    [[ -n "$CASE_DIR" && -n "$MANIFEST_DIR" ]] \
        || hardstop "Internal state resolution failed for existing case" "$EX_SOFTWARE"

    assert_dir_exists "$CASE_DIR"
    assert_dir_exists "$MANIFEST_DIR"

    LATEST_RUN_MANIFEST="$(
        find_latest_manifest "$MANIFEST_DIR" "run_manifest" "$RUN_ID"
    )" || hardstop "No prior run manifest found for ${INPUT[CASE]}" "$EX_DATAERR"

    LATEST_CASE_MANIFEST="$(
        find_latest_manifest "$MANIFEST_DIR" "case_manifest" "$RUN_ID"
    )" || hardstop "No prior case manifest found for ${INPUT[CASE]}" "$EX_DATAERR"

    assert_file_exists "$LATEST_RUN_MANIFEST"
    assert_file_exists "$LATEST_CASE_MANIFEST"

    debug "Latest prior run manifest: <$LATEST_RUN_MANIFEST>"
    debug "Latest prior case manifest: <$LATEST_CASE_MANIFEST>"
}

validate_add_state() {
    local file

    # Existence is checked as a complete batch before the workflow copies any
    # evidence. This preserves the current all-inputs-first validation behavior.
    for file in "${FILES[@]}"; do
        assert_file_exists "$file"
        debug "Verifying input file exists: <$file>"
    done

    log "File type validated: ${INPUT[TYPE]}"
}

validate_collect_state() {
    debug "Running validate_config COLLECT"

    # PROFILE has a default even when the operator does not provide the option.
    (( WAS_SET[PROFILE] )) \
        || warn "No input --profile chosen; using 'default'"

    info "${INPUT[PROFILE]} selected"
}

validate_config() {
    local selected_count

    info "running validate_config..."

    # Layer 1: command cardinality and schema-level option contracts.
    selected_count="$(command_count)"
    debug "command_count: $selected_count"

    (( selected_count == 1 )) \
        || hardstop "Select exactly one command: new, add, collect, verify, or bundle" "$EX_USAGE"

    validate_command_contract
    validate_enum_options
    validate_case_prefix

    # Layer 2: command-specific state and persistent-case checks.
    if (( COMMANDS[NEW] )); then
        validate_new_case_state
        return 0
    fi

    validate_existing_case_id
    load_existing_case_state

    if (( COMMANDS[ADD] )); then
        validate_add_state
    fi

    if (( COMMANDS[COLLECT] )); then
        validate_collect_state
    fi

    if (( COMMANDS[VERIFY] )); then
        debug "Running validate_config VERIFY"
    fi

    if (( COMMANDS[BUNDLE] )); then
        debug "Running validate_config BUNDLE"
    fi
}

# =============================================================================
# endregion S9. Configuration validation
# =============================================================================

# =============================================================================
# region S10. Command workflows
# =============================================================================

# --- S10.1 NEW case construction -----------------------------------------

create_new_case_artifacts() {
    # Case manifest first, then the evidence/derived/commands/reports branches.
    # The ordering mirrors the directory tree shown in `tracehold --help`.
    debug "Case_ID set: ${INPUT[CASE]}"

    ensure_dir "${CASE_DIR}"
    ensure_dir "$MANIFEST_DIR"
    make_case_manifest "${MANIFEST_DIR}/case_manifest_${RUN_ID}.txt"

    # Future snapshot writers remain deliberately disabled in v1.1.0.
    # environment_check "${CASE_DIR}/manifest/environment.txt"
    # software_check "${CASE_DIR}/manifest/software_versions.txt"
    # verify_checksums "${CASE_DIR}/manifest/checksums.sha256"

    ensure_dir "${CASE_DIR}/evidence"
    ensure_dir "${CASE_DIR}/evidence/raw"
    ensure_dir "${CASE_DIR}/evidence/photos"
    ensure_dir "${CASE_DIR}/evidence/logs"
    ensure_dir "${CASE_DIR}/evidence/operator_notes"

    ensure_dir "${CASE_DIR}/derived"
    ensure_dir "${CASE_DIR}/derived/timelines"
    ensure_dir "${CASE_DIR}/derived/extracts"
    ensure_dir "${CASE_DIR}/derived/figures"

    ensure_dir "${CASE_DIR}/commands"
    write_file "${CASE_DIR}/commands/collection.log" "test collection.log"
    write_file "${CASE_DIR}/commands/replay.sh" "test replay.sh"

    ensure_dir "${CASE_DIR}/reports"
    initial_triage "${CASE_DIR}/reports/initial_triage.md"
    write_file "${CASE_DIR}/reports/handoff.md" "test handoff.md"
}

# --- S10.2 ADD evidence routing ------------------------------------------

evidence_target_dir() {
    local evidence_type="${1:?evidence_target_dir requires an evidence type}"

    # Keep public evidence types decoupled from their on-disk directory names.
    case "$evidence_type" in
        raw)   printf '%s\n' "${CASE_DIR}/evidence/raw" ;;
        photo) printf '%s\n' "${CASE_DIR}/evidence/photos" ;;
        log)   printf '%s\n' "${CASE_DIR}/evidence/logs" ;;
        note)  printf '%s\n' "${CASE_DIR}/evidence/operator_notes" ;;
        *)
            hardstop \
                "Unknown file type. Available: 'raw','photo','log','note'" \
                "$EX_USAGE"
            ;;
    esac
}

add_evidence_files() {
    local file
    local file_path
    local file_name
    local target_dir

    target_dir="$(evidence_target_dir "${INPUT[TYPE]}")"

    # Validation has already confirmed every source is a regular file. Resolve
    # each absolute path only at the point where it enters the copy transaction.
    for file in "${FILES[@]}"; do
        file_path="$(realpath "$file")"
        file_name="$(basename "$file")"

        debug "file_path: $file_path"
        debug "file_name: $file_name"

        copy_evidence "$file_name" "$file_path" "$target_dir"
    done
}

# --- S10.3 Scaffold visibility -------------------------------------------

run_scaffolded_command_hooks() {
    # These hooks intentionally remain no-ops. Keeping them visible in the
    # orchestrator makes unfinished command scope difficult to mistake as done.
    if (( COMMANDS[COLLECT] )); then
        debug "Collect = ${COMMANDS[COLLECT]}"
    fi

    if (( COMMANDS[VERIFY] )); then
        debug "Verify = ${COMMANDS[VERIFY]}"
    fi

    if (( COMMANDS[BUNDLE] )); then
        debug "${COMMANDS[BUNDLE]}"
    fi
}

# --- S10.4 Workflow orchestrator -----------------------------------------

run_workflow() {
    info "Run ID: $RUN_ID"

    # Every command records invocation context before command-specific work.
    make_run_manifest "${MANIFEST_DIR}/run_manifest_${RUN_ID}.txt"

    if (( COMMANDS[NEW] )); then
        create_new_case_artifacts
    fi

    if (( COMMANDS[ADD] )); then
        add_evidence_files
    fi

    run_scaffolded_command_hooks

    # Preserve the current summary contract and terminal output exactly.
    write_summary "${MANIFEST_DIR}/summary_${RUN_ID}.txt" "ok"
    log "tracehold: workflow complete"
    log "Case-ID: ${INPUT[CASE]}"
}

