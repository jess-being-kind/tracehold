# =============================================================================
# region S3. Command execution and filesystem persistence
# =============================================================================

# --- S3.1 Dry-run execution adapter --------------------------------------

# Filesystem mutations routed through run_cmd inherit Tracehold's dry-run
# contract. capture_cmd is reserved for commands whose stdout is data.
run_cmd() {
    if (( SCRIPT[APPLY] )); then
        debug "RUN: $(printf '%q ' "$@")"
        "$@"
    else
        printf "[DRY RUN] "
        printf "%q " "$@"
        printf "\n"
    fi
}

capture_cmd() {
    debug "CAPTURE: $(printf '%q ' "$@")"
    "$@"
}

# --- S3.2 Generic filesystem writers -------------------------------------

ensure_dir() { run_cmd mkdir -p "$1"; }

# Existing generated artifacts are retained beside their replacement.
backup_if_exists() {
    local path="$1"
    [[ -e "$path" || -L "$path" ]] || return 0
    local backup="${path}.bak.${RUN_ID}"
    warn "Backing up existing path: $path -> $backup"
    run_cmd cp -a "$path" "$backup"
}

# write_file is the atomic writer used by generated Tracehold artifacts.
write_file() {
    local path="$1"
    local content="$2"
    if [[ -e "$path" && "${SCRIPT[FORCE]}" -ne 1 ]] && (( SCRIPT[SELF_TEST] == 0 )); then
        warn "File exists, skipping: $path  Use --force to replace after backup."
        return 0
	elif [[ -e "$path" && "${SCRIPT[SELF_TEST]}" -eq 1 ]]; then
		info "Appending self-test manifest to existing manifest file: $path"
    fi
    ensure_dir "$(dirname "$path")"
    [[ -e "$path" || -L "$path" ]] && backup_if_exists "$path"
    if (( SCRIPT[APPLY] )); then
        local tmp="${path}.tmp.$$"
		if (( SCRIPT[SELF_TEST] && !COMMANDS[NEW])); then
			cp -a "$path" "$tmp"
			printf "%s" "$content" >> "$tmp"
			log "Appended to $path"
		else
			printf "%s" "$content" > "$tmp"
			log "Wrote $path"
		fi
		mv "$tmp" "$path"
    else
        printf "[DRY RUN] write %q\n" "$path"
    fi
}

write_file_stream() {
    local path="$1"
    local content
    content="$(cat)"
    write_file "$path" "$content"$'\n'
}

append_unique_line() {
    local line="${1:?append_unique_line requires content}"
    local file="${2:?append_unique_line requires a file}"

    grep -Fqx -- "$line" "$file" 2>/dev/null ||
        printf '%s\n' "$line" >> "$file"
}

# --- S3.3 Evidence ingestion ---------------------------------------------

# Preserve the current source-hash, intermediate-copy, and destination-copy
# sequence. Integrity/provenance upgrades remain separate roadmap work.
copy_evidence() {
    local file_name="${1:?copy_evidence requires a file name}"
    local file_path="${2:?copy_evidence requires an absolute file path}"
    local target_dir="${3:?copy_evidence requires a target directory}"
    local target_path="${target_dir}/${file_name}"
    local write_sha

    ensure_dir "$target_dir"

    if [[ -e "$target_path" || -L "$target_path" ]]; then
        (( SCRIPT[FORCE] )) \
            || hardstop \
                "Evidence already exists: $target_path  Use --force to preserve a backup and replace it." \
                "$EX_CANTCREAT"
        backup_if_exists "$target_path"
    fi

    write_sha=$(sha256sum "${file_path}")
    run_cmd append_unique_line "$write_sha" "${LATEST_CASE_MANIFEST}"

    run_cmd cp -a -- "$file_path" "$target_path"
}

# --- S3.4 Persistent-state discovery -------------------------------------

# Select the newest well-formed prior manifest older than the current run.
find_latest_manifest() {
    local manifest_dir="${1:?find_latest_manifest requires a manifest directory}"
    local manifest_type="${2:?find_latest_manifest requires a manifest type}"
    local current_run_id="${3:?find_latest_manifest requires a current run ID}"

    local path
    local filename
    local timestamp
    local latest_path=""
    local latest_timestamp=""
    local -a candidates=()

    shopt -s nullglob
    candidates=( "${manifest_dir}/${manifest_type}_"*.txt )
    shopt -u nullglob

    for path in "${candidates[@]}"; do
        filename="${path##*/}"
        timestamp="${filename#"${manifest_type}_"}"
        timestamp="${timestamp%.txt}"

        debug "Manifest candidate: <$path>"
        debug "Extracted manifest timestamp: <$timestamp>"

        [[ "$timestamp" =~ ^[0-9]{8}_[0-9]{6}_UTC$ ]] || {
            debug "Skipping malformed timestamp: <$timestamp>"
            continue
        }

        [[ "$timestamp" < "$current_run_id" ]] || {
            debug "Skipping current or newer timestamp: <$timestamp>"
            continue
        }

        if [[ -z "$latest_timestamp" || "$timestamp" > "$latest_timestamp" ]]; then
            latest_timestamp="$timestamp"
            latest_path="$path"
            debug "Updated latest manifest: <$latest_path>"
        fi
    done

    [[ -n "$latest_path" ]] || return 1

    # Function contract: stdout contains only the selected path.
    printf '%s\n' "$latest_path"
}

