# --- S8.1 Scalar and variadic assignment ---------------------------------

set_cli_value() {
    local option="$1"
    local destination_name="$2"
    local was_set_name="$3"
    local value="${4-}"
    local -n destination="$destination_name"
    local -n was_set="$was_set_name"

    [[ -n "$value" ]] || hardstop "Missing value for ${option}" "$EX_IOERR"
    [[ "$value" != -* ]] \
        || hardstop \
            "Missing value for ${option}; found option '${value}' instead" \
            "$EX_IOERR"

    destination="$value"
    was_set=1
}

collect_cli_values() {
    local option="$1"
    local destination_name="$2"
    local was_set_name="$3"
    local -n destination="$destination_name"
    local -n was_set="$was_set_name"
    local count=0

    shift 3

    while (( $# > 0 )) && [[ "$1" != -* ]]; do
        destination+=("$1")
        (( count += 1 ))
        shift
    done

    (( count > 0 )) || hardstop "${option} requires at least one value" "$EX_IOERR"

    was_set=1
    CLI_VALUES_CONSUMED="$count"
}

# --- S8.2 Schema-directed token parsing ----------------------------------

select_command() {
    local command="${1:?select_command requires a command}"
    local command_key="${COMMAND_KEY_BY_NAME[$command]-}"

    [[ -n "$command_key" ]] || hardstop "Unknown command: ${command}" "$EX_IOERR"
    (( $(command_count) == 0 )) || hardstop "Only one command may be selected" "$EX_USAGE"

    COMMANDS[$command_key]=1
    debug "Command '${command}' selected"
}

parse_schema_option() {
    local option="${1:?parse_schema_option requires an option}"
    local option_key="${OPTION_KEY_BY_CLI[$option]-}"
    local kind destination_name was_set_name

    [[ -n "$option_key" ]] || return 1

    kind="${OPTION_KIND[$option_key]}"
    destination_name="${OPTION_DEST[$option_key]}"
    was_set_name="${OPTION_TRACK[$option_key]}"

    case "$kind" in
        scalar|enum|case|dir)
            set_cli_value "$option" "$destination_name" "$was_set_name" "${2-}"
            PARSE_TOKENS_CONSUMED=2
            ;;
        variadic|file_variadic)
            shift
            collect_cli_values "$option" "$destination_name" "$was_set_name" "$@"
            PARSE_TOKENS_CONSUMED=$(( CLI_VALUES_CONSUMED + 1 ))
            ;;
        flag_true|flag_false)
            local -n destination="$destination_name"
            local -n was_set="$was_set_name"

            if [[ "$kind" == "flag_true" ]]; then
                destination=1
            else
                destination=0
            fi
            was_set=1
            PARSE_TOKENS_CONSUMED=1
            ;;
        *)
            hardstop "Internal error: unsupported option kind '${kind}' for ${option}" "$EX_SOFTWARE"
            ;;
    esac
}

# --- S8.3 Canonical input synchronization --------------------------------

# Variadic arrays remain the parser-facing representation; INPUT receives
# the joined values expected by current manifests and reports.
sync_variadic_inputs() {
    if (( WAS_SET[ASSET] )); then
        INPUT[ASSET]="$(join_by ', ' "${ASSETS[@]}")"
    fi

    if (( WAS_SET[SITE] )); then
        INPUT[SITE]="$(join_by ', ' "${SITES[@]}")"
    fi

    if (( WAS_SET[OWNER] )); then
        INPUT[OWNER]="$(join_by ', ' "${OWNERS[@]}")"
    fi

    if (( WAS_SET[RECENT_CHANGE] )); then
        INPUT[RECENT_CHANGE]="$(join_by ', ' "${RECENT_CHANGES[@]}")"
    fi

    if (( WAS_SET[FILE] )); then
        INPUT[FILE]="$(join_by ', ' "${FILES[@]}")"
    fi
}

# --- S8.4 Top-level argument loop ----------------------------------------

# The parser handles schema options first, command words second, then the
# small set of global meta-options that do not belong to a command contract.
parse_args() {
    local CLI_VALUES_CONSUMED=0
    local PARSE_TOKENS_CONSUMED=0

    while (( $# > 0 )); do
        if [[ -n "$1" && -n "${OPTION_KEY_BY_CLI[$1]-}" ]]; then
            parse_schema_option "$@"
            shift "$PARSE_TOKENS_CONSUMED"
            continue
        fi

        if [[ -n "$1" && -n "${COMMAND_KEY_BY_NAME[$1]-}" ]]; then
            select_command "$1"
            shift
            continue
        fi

        case "$1" in
            --self-test)
                SCRIPT[SELF_TEST]=1
                shift
                ;;
            --completion)
                [[ "${2-}" == "bash" ]] \
                    || hardstop "--completion currently supports only: bash" "$EX_USAGE"
                print_bash_completion
                exit 0
                ;;
            --version)
                printf '%s\n' "$VERSION"
                exit 0
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            --)
                shift
                (( $# == 0 )) \
                    || hardstop "Unexpected positional argument after --: $1" "$EX_IOERR"
                break
                ;;
            -*)
                hardstop "Unknown option: $1" "$EX_USAGE"
                ;;
            *)
                hardstop "Unknown argument: $1" "$EX_IOERR"
                ;;
        esac
    done

    sync_variadic_inputs
}

