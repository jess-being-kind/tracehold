# --- Directory helpers -------------------------------------------------------

ensure_dir() { run_cmd mkdir -p "$1"; }

backup_if_exists() {
    local path="$1"
    [[ -e "$path" || -L "$path" ]] || return 0
    local backup="${path}.bak.${RUN_ID}"
    warn "Backing up existing path: $path -> $backup"
    run_cmd cp -a "$path" "$backup"
}

# --- Safe file writing -------------------------------------------------------

write_file() {
    local path="$1"
    local content="$2"
    if [[ -e "$path" && "${SCRIPT[FORCE]}" -ne 1 ]] && (( SCRIPT[SELF_TEST] == 0 )); then
        warn "File exists, skipping: $path  Use --force to replace after backup."
        return 0
	elif [[ -e "$path" && "${SCRIPT[SELF_TEST]}" -eq 1 ]]; then
		info "Appending self-test manifest to existing manifest file: $path"
    fi
    ensure_dir "$(dirname "$path")"
    [[ -e "$path" || -L "$path" ]] && backup_if_exists "$path"
    if (( SCRIPT[APPLY] )); then
        local tmp="${path}.tmp.$$"
		if (( SCRIPT[SELF_TEST] && !COMMANDS[NEW])); then
			cp -a "$path" "$tmp"
			printf "%s" "$content" >> "$tmp"
			log "Appended to $path"
		else
			printf "%s" "$content" > "$tmp"
			log "Wrote $path"
		fi
		mv "$tmp" "$path"
    else
        printf "[DRY RUN] write %q\n" "$path"
    fi
}

write_file_stream() {
    local path="$1"
    local content
    content="$(cat)"
    write_file "$path" "$content"$'\n'
}

# =============================================================================
# endregion S3. Path and file helpers
# =============================================================================

# =============================================================================
# region S4. Command execution
# =============================================================================

run_cmd() {
    if (( SCRIPT[APPLY] )); then
        debug "RUN: $(printf '%q ' "$@")"
        "$@"
    else
        printf "[DRY RUN] "
        printf "%q " "$@"
        printf "\n"
    fi
}

capture_cmd() {
    debug "CAPTURE: $(printf '%q ' "$@")"
    "$@"
}

