# --- S7.1 Shell adapter generator ----------------------------------------

# The emitted adapter delegates decisions back to Tracehold, keeping the
# installed completion thin and the command schema authoritative.
print_bash_completion() {
    cat <<'BASH_COMPLETION'
# Bash programmable completion for Tracehold.
# Generated by: tracehold --completion bash

_tracehold() {
    local executable="${COMP_WORDS[0]}"
    local mode
    local -a response=()

    mapfile -t response < <(
        "$executable" __complete "$COMP_CWORD" "${COMP_WORDS[@]}" 2>/dev/null
    )

    mode="${response[0]-}"
    case "$mode" in
        __TRACEHOLD_VALUES__)
            compopt +o bashdefault +o default 2>/dev/null || true
            COMPREPLY=( "${response[@]:1}" )
            ;;
        __TRACEHOLD_FILES__)
            compopt -o filenames
            COMPREPLY=( "${response[@]:1}" )
            ;;
        __TRACEHOLD_DIRS__)
            compopt -o filenames
            COMPREPLY=( "${response[@]:1}" )
            ;;
        __TRACEHOLD_NONE__)
            compopt +o bashdefault +o default 2>/dev/null || true
            COMPREPLY=()
            ;;
        *)
            COMPREPLY=()
            ;;
    esac
}

complete -o bashdefault -o default -F _tracehold \
    tracehold tracehold.sh ./tracehold.sh
BASH_COMPLETION
}

# --- S7.2 Completion-state inspection ------------------------------------

completion_option_is_present() {
    local target_key="${1:?completion_option_is_present requires an option key}"
    local cword="${2:?completion_option_is_present requires COMP_CWORD}"
    shift 2
    local -a words=( "$@" )
    local i token token_key

    for (( i = 1; i < cword; i++ )); do
        token="${words[i]-}"
        [[ -n "$token" ]] || continue
        token_key="${OPTION_KEY_BY_CLI[$token]-}"
        [[ "$token_key" == "$target_key" ]] && return 0
    done

    return 1
}

completion_option_has_value() {
    local target_key="${1:?completion_option_has_value requires an option key}"
    local cword="${2:?completion_option_has_value requires COMP_CWORD}"
    shift 2
    local -a words=( "$@" )
    local i token token_key

    for (( i = 1; i < cword; i++ )); do
        token="${words[i]-}"
        [[ -n "$token" ]] || continue
        token_key="${OPTION_KEY_BY_CLI[$token]-}"
        if [[ "$token_key" == "$target_key" ]]; then
            if (( i + 1 < cword )) &&
               [[ -n "${words[i + 1]-}" ]] &&
               [[ "${words[i + 1]}" != -* ]]; then
                return 0
            fi
        fi
    done

    return 1
}

completion_option_satisfied() {
    local option_key="${1:?completion_option_satisfied requires an option key}"
    local cword="${2:?completion_option_satisfied requires COMP_CWORD}"
    shift 2
    local kind="${OPTION_KIND[$option_key]}"

    case "$kind" in
        flag_true|flag_false)
            completion_option_is_present "$option_key" "$cword" "$@"
            ;;
        *)
            completion_option_has_value "$option_key" "$cword" "$@"
            ;;
    esac
}

completion_output_dir() {
    local cword="${1:?completion_output_dir requires COMP_CWORD}"
    shift
    local -a words=( "$@" )
    local output_dir="${OUTPUT_DIR:-${ENGINEERING_DIR}/projects/active/${SCRIPT_NAME%.sh}/cases}"
    local i token token_key

    for (( i = 1; i < cword; i++ )); do
        token="${words[i]-}"
        [[ -n "$token" ]] || continue
        token_key="${OPTION_KEY_BY_CLI[$token]-}"
        if [[ "$token_key" == "OUTPUT_DIR" ]] && (( i + 1 < cword )); then
            output_dir="${words[i + 1]}"
            break
        fi
    done

    case "$output_dir" in
        '~') output_dir="$HOME" ;;
        '~/'*) output_dir="$HOME/${output_dir#~/}" ;;
    esac

    printf '%s\n' "$output_dir"
}

# --- S7.3 Completion response backend ------------------------------------

completion_emit_values() {
    local current="${1-}"
    shift || true
    local candidate

    printf '__TRACEHOLD_VALUES__\n'
    for candidate in "$@"; do
        [[ "$candidate" == "$current"* ]] && printf '%s\n' "$candidate"
    done
}

# Output begins with a private mode sentinel consumed by the generated Bash
# adapter; normal users should never need to call __complete directly.
complete_cli() {
    local cword="${1-}"
    shift || true
    local -a words=( "$@" )
    local current previous command_key option_key kind output_dir path
    local -a candidates=()
    local i

    [[ "$cword" =~ ^[0-9]+$ ]] || return 0

    current="${words[cword]-}"
    previous="${words[cword - 1]-}"
    command_key=""

    for (( i = 1; i < cword; i++ )); do
        [[ -n "${words[i]-}" ]] || continue
        if [[ -n "${COMMAND_KEY_BY_NAME[${words[i]}]-}" ]]; then
            command_key="${COMMAND_KEY_BY_NAME[${words[i]}]}"
            break
        fi
    done

    if [[ "$previous" == "--completion" ]]; then
        completion_emit_values "$current" bash
        return 0
    fi

    if [[ -z "$command_key" ]]; then
        candidates=( new add collect verify bundle --help --version --self-test --completion )
        completion_emit_values "$current" "${candidates[@]}"
        return 0
    fi

    option_key=""
    if [[ -n "$previous" ]]; then
        option_key="${OPTION_KEY_BY_CLI[$previous]-}"
    fi
    if [[ -n "$option_key" ]]; then
        kind="${OPTION_KIND[$option_key]}"
        case "$kind" in
            enum)
                IFS=' ' read -r -a candidates <<< "${OPTION_ENUM[$option_key]}"
                completion_emit_values "$current" "${candidates[@]}"
                return 0
                ;;
            case)
                output_dir="$(completion_output_dir "$cword" "${words[@]}")"
                candidates=()
                if [[ -d "$output_dir" ]]; then
                    shopt -s nullglob
                    for path in "$output_dir"/"${CASE_PREFIX}"_*; do
                        [[ -d "$path" ]] || continue
                        candidates+=( "${path##*/}" )
                    done
                    shopt -u nullglob
                fi
                completion_emit_values "$current" "${candidates[@]}"
                return 0
                ;;
            file_variadic)
                printf '__TRACEHOLD_FILES__\n'
                compgen -f -- "$current"
                return 0
                ;;
            dir)
                printf '__TRACEHOLD_DIRS__\n'
                compgen -d -- "$current"
                return 0
                ;;
            scalar|variadic)
                printf '__TRACEHOLD_NONE__\n'
                return 0
                ;;
        esac
    fi

    local -a required_options=() allowed_options=()
    IFS=' ' read -r -a required_options <<< "${COMMAND_REQUIRED[$command_key]}"
    IFS=' ' read -r -a allowed_options <<< "${COMMAND_ALLOWED[$command_key]}"

    for option_key in "${required_options[@]}"; do
        if ! completion_option_satisfied "$option_key" "$cword" "${words[@]}"; then
            completion_emit_values "$current" "${OPTION_CLI[$option_key]}"
            return 0
        fi
    done

    candidates=()
    for option_key in "${allowed_options[@]}"; do
        if [[ "$option_key" == "APPLY" || "$option_key" == "DRY_RUN" ]]; then
            if completion_option_is_present APPLY "$cword" "${words[@]}" ||
               completion_option_is_present DRY_RUN "$cword" "${words[@]}"; then
                continue
            fi
        elif completion_option_satisfied "$option_key" "$cword" "${words[@]}"; then
            continue
        fi

        candidates+=( "${OPTION_CLI[$option_key]}" )
    done

    completion_emit_values "$current" "${candidates[@]}"
}

