# --- S6.1 Shared-schema queries ------------------------------------------

command_count() {
    local command_key
    local count=0

    for command_key in "${COMMAND_KEYS[@]}"; do
        (( count += COMMANDS[$command_key] ))
    done

    printf '%d\n' "$count"
}

active_command_key() {
    local command_key

    for command_key in "${COMMAND_KEYS[@]}"; do
        if (( COMMANDS[$command_key] )); then
            printf '%s\n' "$command_key"
            return 0
        fi
    done

    return 1
}

option_is_set() {
    local option_key="${1:?option_is_set requires an option key}"
    (( ${WAS_SET[$option_key]:-0} == 1 ))
}

word_in_schema_list() {
    local needle="${1:?word_in_schema_list requires a value}"
    local list="${2-}"
    local item
    local -a items=()

    IFS=' ' read -r -a items <<< "$list"
    for item in "${items[@]}"; do
        [[ "$item" == "$needle" ]] && return 0
    done

    return 1
}

# --- S6.2 Generated contract presentation --------------------------------

format_contract_option() {
    local option_key="${1:?format_contract_option requires an option key}"
    local cli="${OPTION_CLI[$option_key]}"
    local kind="${OPTION_KIND[$option_key]}"
    local metavar="${OPTION_METAVAR[$option_key]-}"

    case "$kind" in
        flag_true|flag_false)
            printf '%s' "$cli"
            ;;
        variadic|file_variadic)
            printf '%s %s [...]' "$cli" "$metavar"
            ;;
        *)
            printf '%s %s' "$cli" "$metavar"
            ;;
    esac
}

print_command_summary() {
    local command_key

    printf 'Commands:\n'
    for command_key in "${COMMAND_KEYS[@]}"; do
        printf '\t%-9s %s\n' \
            "${COMMAND_NAME[$command_key]}" \
            "${COMMAND_DESCRIPTION[$command_key]}"
    done
}

print_command_contracts() {
    local command_key option_key
    local required_text allowed_text
    local -a required=() allowed=() optional=()

    printf 'Command contracts (generated from the shared schema):\n'

    for command_key in "${COMMAND_KEYS[@]}"; do
        required_text="${COMMAND_REQUIRED[$command_key]}"
        allowed_text="${COMMAND_ALLOWED[$command_key]}"
        IFS=' ' read -r -a required <<< "$required_text"
        IFS=' ' read -r -a allowed <<< "$allowed_text"
        optional=()

        for option_key in "${allowed[@]}"; do
            if ! word_in_schema_list "$option_key" "$required_text"; then
                optional+=( "$option_key" )
            fi
        done

        printf '\t%s\n' "${COMMAND_NAME[$command_key]}"
        printf '\t  required:\n'
        if (( ${#required[@]} == 0 )); then
            printf '\t    <none>\n'
        else
            for option_key in "${required[@]}"; do
                printf '\t    '
                format_contract_option "$option_key"
                printf '\n'
            done
        fi

        printf '\t  optional:\n'
        if (( ${#optional[@]} == 0 )); then
            printf '\t    <none>\n'
        else
            for option_key in "${optional[@]}"; do
                printf '\t    '
                format_contract_option "$option_key"
                printf '\n'
            done
        fi
    done
}

