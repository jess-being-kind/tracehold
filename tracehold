# =============================================================================
# region S11. Self-test
# =============================================================================

# --- S11.1 Temporary-directory smoke test --------------------------------

# Preserve the existing NEW-command smoke test and its artifact assertions.
run_self_test() {
    local tmp_dir
    local expected_case_dir
    local old_apply="${SCRIPT[APPLY]}"
    local old_output_dir="${INPUT[OUTPUT_DIR]}"

    debug "run_self_test executing..."

    tmp_dir="$(mktemp -d)"
    trap 'rm -rf "$tmp_dir"' RETURN

    SCRIPT[APPLY]=1
    INPUT[OUTPUT_DIR]="$tmp_dir"
    INPUT[TITLE]="self_test"
    INPUT[DESCRIPTION]="Tracehold v2 smoke test"
    INPUT[SEVERITY]="P4"
    INPUT[ASSET]="A_000"

    WAS_SET[TITLE]=1
    WAS_SET[DESCRIPTION]=1
    WAS_SET[SEVERITY]=1
    WAS_SET[ASSET]=1

    COMMANDS[NEW]=1
    COMMANDS[ADD]=0
    COMMANDS[COLLECT]=0
    COMMANDS[VERIFY]=0
    COMMANDS[BUNDLE]=0

    resolve_state
    validate_config
    run_workflow

    expected_case_dir="$CASE_DIR"
    assert_dir_exists "$expected_case_dir"
    assert_file_exists "${MANIFEST_DIR}/run_manifest_${RUN_ID}.txt"
    assert_file_exists "${MANIFEST_DIR}/case_manifest_${RUN_ID}.txt"
    assert_file_exists "${MANIFEST_DIR}/summary_${RUN_ID}.txt"
    assert_file_exists "${CASE_DIR}/reports/initial_triage.md"

    SCRIPT[APPLY]="$old_apply"
    INPUT[OUTPUT_DIR]="$old_output_dir"

    rm -rf "$tmp_dir"
    trap - RETURN

    log "Self-test passed"
}

