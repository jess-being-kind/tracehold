# --- S2.1 Preconditions and environment helpers --------------------------

# Small fail-fast guards used by validation and V&V code.
require_command() { command -v "$1" >/dev/null 2>&1 || hardstop "Missing required command: $1" "$EX_NOINPUT"; }

assert_file_exists() { [[ -f "$1" ]] || hardstop "Expected file does not exist: $1" "$EX_DATAERR"; }

assert_dir_exists() { [[ -d "$1" ]] || hardstop "Expected directory does not exist: $1" "$EX_DATAERR"; }

is_positive_integer() { [[ "${1:-}" =~ ^[1-9][0-9]*$ ]]; }

is_yes() { case "${1,,}" in y|yes|true|1|on) return 0 ;; *) return 1 ;; esac; }

path_prepend() {
    local dir="${1:?path_prepend requires a directory}"
    [[ -d "$dir" ]] || return 0
    case ":$PATH:" in *":$dir:"*) ;; *) export PATH="$dir:$PATH" ;; esac
}

# --- S2.2 Text and list helpers ------------------------------------------

# These helpers serialize variadic CLI buffers into the existing manifest
# representation. They intentionally do not change the file format.
join_by() {
    local delimiter="$1"; shift || true
    local first=1 item
    for item in "$@"; do
        if (( first )); then printf "%s" "$item"; first=0; else printf "%s%s" "$delimiter" "$item"; fi
    done
}

split_csv() {
    local csv="${1:-}" item
    IFS=',' read -r -a _items <<< "$csv"
    for item in "${_items[@]}"; do
        item="${item#${item%%[![:space:]]*}}"
        item="${item%${item##*[![:space:]]}}"
        [[ -n "$item" ]] && printf "%s\n" "$item"
    done
}

