# =============================================================================
# region S12. Entrypoint
# =============================================================================

# --- S12.1 Adapter dispatch and primary lifecycle ------------------------

# Completion is handled before strict runtime installation because shell
# completion probes must fail quietly rather than print trap diagnostics.
main() {
    if [[ "${1-}" == "__complete" ]]; then
        shift
        complete_cli "$@"
        return 0
    fi

    if [[ "${1-}" == "--completion" ]]; then
        [[ "${2-}" == "bash" && $# -eq 2 ]] \
            || hardstop "Usage: ${SCRIPT_NAME} --completion bash" "$EX_USAGE"
        print_bash_completion
        return 0
    fi

    install_runtime

    parse_args "$@"
    resolve_state

    if (( SCRIPT[SELF_TEST] )); then
        run_self_test
    else
        validate_config
        run_workflow
    fi
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi

