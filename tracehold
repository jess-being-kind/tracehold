# --- S4.1 Derived case paths ---------------------------------------------

# Convert parsed intent into CASE_DIR/MANIFEST_DIR once, before validation.
resolve_state() {
    if (( COMMANDS[NEW] )); then
        INPUT[CASE]="${CASE_PREFIX}_${RUN_ID}_${INPUT[TITLE]}"
    fi

    [[ -n "${INPUT[CASE]}" ]] || return 0

    CASE_DIR="${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}"
    MANIFEST_DIR="${CASE_DIR}/manifest"

    debug "Resolved case directory: <$CASE_DIR>"
