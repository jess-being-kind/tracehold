        ensure_dir "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/commands"
        write_file "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/commands/collection.log" "test collection.log"
        write_file "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/commands/replay.sh" "test replay.sh"

        ensure_dir "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/reports"
        initial_triage "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/reports/initial_triage.md"
        write_file "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/reports/handoff.md" "test handoff.md"
    fi

    if (( COMMANDS[ADD] )); then

        assert_dir_exists "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}"
        assert_file_exists "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/manifest/case_manifest.txt"

        debug "Adding ${INPUT[TYPE]} file: ${INPUT[FILE]} to ${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}"

        if [[ -f "${INPUT[FILE]}" && -e "${INPUT[FILE]}" ]]; then

            case "${INPUT[TYPE]}" in
                raw) ;;
                photo)  ;;
                log)  ;;
                note) ;;
                *) warn "Unknown file type. Available: 'raw','photo','log','note'" ;;
            esac
        fi

    fi

    if (( COMMANDS[COLLECT] )); then
        debug "Collect = ${COMMANDS[COLLECT]}"
    fi

    if (( COMMANDS[VERIFY] )); then
        debug "Verify = ${COMMANDS[VERIFY]}"
    fi

    if (( COMMANDS[BUNDLE] )); then
        debug "${COMMANDS[BUNDLE]}"
    fi

    write_summary "${INPUT[OUTPUT_DIR]}/logs/summary_${RUN_ID}.txt" "ok"
    log "tracehold: workflow complete"
}

# --- Self-test ---------------------------------------------------------------

run_self_test() {
	debug "run_self_test executing..."
    local tmp_dir old_apply old_output
    tmp_dir="$(mktemp -d)"
    info "Self-test temp dir: $tmp_dir"
    old_apply="${SCRIPT[APPLY]}"
    old_output="${INPUT[OUTPUT_DIR]}"

	SCRIPT[APPLY]=1
    INPUT[OUTPUT_DIR]="$tmp_dir"
    INPUT[PROFILE]="${INPUT[PROFILE]:-default}"

    info "Output Directory: ${INPUT[OUTPUT_DIR]}"
    info "Input Path: ${INPUT[PROFILE]}"

	for set in "${!WAS_SET[@]}"; do
		debug "WAS_SET: $set - ${WAS_SET[$set]}"
	done

	for option in "${!INPUT[@]}"; do
		debug "INPUT: $option- ${INPUT[$option]}"
	done

	for setting in "${!SCRIPT[@]}"; do
		debug "SCRIPT: $setting - ${SCRIPT[$setting]}"
	done

	for key in "${!COMMAND_KEYS[@]}"; do
		debug "$key"
		case $key in
			0|NEW)
				debug "running 'new' self-test..."
				COMMANDS[NEW]=1

				WAS_SET[CASE]=0
				WAS_SET[TITLE]=1
				WAS_SET[DESCRIPTION]=1
				WAS_SET[SEVERITY]=1
				WAS_SET[ASSET]=1

				INPUT[TITLE]="self_test"
				INPUT[DESCRIPTION]="this is a self-test run for smoke-test/functionality only"
				INPUT[SEVERITY]="P4"
				INPUT[ASSET]="A_000"
			;;

			1|ADD)
				debug "running 'add' self-test..."
				COMMANDS[NEW]=0
				COMMANDS[ADD]=1

				WAS_SET[TITLE]=0
				WAS_SET[CASE]=1
				WAS_SET[FILE]=1
				WAS_SET[TYPE]=1

				if (( SCRIPT[SELF_TEST] )); then
					[[ -f "${INPUT[OUTPUT_DIR]}/input_test_file.txt" ]] || { \
					touch "${INPUT[OUTPUT_DIR]}/input_test_file.txt" && \
					log "Created ${INPUT[OUTPUT_DIR]}/input_test_file.txt"
					}
				fi

				INPUT[CASE]="${CASE_PREFIX}_${RUN_ID}_${INPUT[TITLE]}"
				INPUT[FILE]="${INPUT[OUTPUT_DIR]}/input_test_file.txt"
				INPUT[TYPE]="photo"
			;;

			2|COLLECT)
				debug "running 'collect' self-test..."
				COMMANDS[ADD]=0
				COMMANDS[COLLECT]=1

				WAS_SET[PROFILE]=1
			;;

			3|VERIFY)
				debug "running 'verify' self-test..."
				COMMANDS[COLLECT]=0
				COMMANDS[VERIFY]=1
			;;

			4|BUNDLE)
				debug "running 'bundle' self-test..."
				COMMANDS[VERIFY]=0
				COMMANDS[BUNDLE]=1
			;;
		esac

		validate_config
		run_workflow
		assert_file_exists "${INPUT[OUTPUT_DIR]}/logs/run_manifest_${RUN_ID}.txt"
		assert_file_exists "${INPUT[OUTPUT_DIR]}/logs/summary_${RUN_ID}.txt"

	done

    SCRIPT[APPLY]="$old_apply"
    INPUT[OUTPUT_DIR]="$old_output"

    ls -lrth "$tmp_dir"
	cat "$tmp_dir"/*/*
	rm -rf "$tmp_dir"
    log "Self-test passed"
}

