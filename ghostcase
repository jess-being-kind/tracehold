# =============================================================================
# region S1. Logging / errors
# =============================================================================

supports_color() { [[ -t 1 && "${NO_COLOR:-}" == "" ]]; }
_color() { supports_color && printf '\033[%sm' "$1" || true; }
_reset() { supports_color && printf '\033[0m' || true; }

log()   { printf "%s[OK]%s %s\n" "$(_color '1;32')" "$(_reset)" "$*"; }
info()  { printf "%s[INFO]%s %s\n" "$(_color '1;34')" "$(_reset)" "$*"; }
warn()  { printf "%s[WARN]%s %s\n" "$(_color '1;33')" "$(_reset)" "$*" >&2; }
err()   { printf "%s[ERR]%s %s\n" "$(_color '1;31')" "$(_reset)" "$*" >&2; }
debug() { (( SCRIPT[VERBOSE] )) && printf "%s[DEBUG]%s %s\n" "$(_color '0;36')" "$(_reset)" "$*" >&2 || true; }
die() { err "$*"; exit 1; }
timestamp() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }

ROOT_BASHPID=""
ERROR_REPORTED=0
CLEANUP_RAN=0

install_runtime() {
    set -Eeuo pipefail
    IFS=$'\n\t'

    ROOT_BASHPID="$BASHPID"

    trap 'on_error "$?" "$LINENO" "$BASH_COMMAND"' ERR
    trap 'cleanup "$?"' EXIT
}

on_error() {
    local status="$1"
    local line="$2"
    local command="$3"

    # Ignore duplicate reports from command-substitution and pipeline subshells.
    [[ "$BASHPID" == "$ROOT_BASHPID" ]] || return 0

    # Ignore additional ERR events after the first root-shell report.
    if (( ERROR_REPORTED )); then
        return 0
    fi
    ERROR_REPORTED=1

    printf 'OOPS: command failed\n' >&2
    printf '    exit code: %d\n' "$status" >&2
    printf '    line: %d\n' "$line" >&2
    printf '    command: %s\n' "$command" >&2
    printf '    process: %s\n' "$BASHPID" >&2
    printf '    function: %s\n' "${FUNCNAME[1]:-main}" >&2
}

cleanup() {
    local status="$1"

    # Only clean up from the shell that actually started main.
    [[ "$BASHPID" == "$ROOT_BASHPID" ]] || return 0

    if (( CLEANUP_RAN )); then
        return 0
    fi
    CLEANUP_RAN=1

    # Prevent accidental re-entry while cleanup itself executes.
    trap - EXIT

    if (( status == 0 )); then
        debug "Cleanup complete."
    else
        warn "Script exited with status ${status}."
    fi
}

