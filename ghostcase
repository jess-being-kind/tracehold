Example:
    ${SCRIPT_NAME} bundle \\
        --case GC_20260715_184500_UTC_link_loss \\
        --apply


────────────────────────────────────────────────────────────────
PATH AND OUTPUT OPTIONS
────────────────────────────────────────────────────────────────

    --case CASE_ID
        Select an existing case.

    --output-dir DIR
        Override the default case-storage directory.

        Default:
            ${INPUT[OUTPUT_DIR]}


────────────────────────────────────────────────────────────────
EXECUTION OPTIONS
────────────────────────────────────────────────────────────────

    --apply
        Perform filesystem changes and execute commands.

    --dry-run
        Print intended actions without changing anything.
        This is the default behavior.

    --force
        Replace generated files after preserving backups.

    -v, --verbose
        Enable detailed diagnostic output.

    --self-test
        Run the built-in smoke test using a temporary directory.

    --version
        Print the current ghostcase version.

    -h, --help
        Show this help text.


