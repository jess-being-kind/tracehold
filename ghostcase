set_cli_value() {
	local option="$1"
    local -n destination="$2"
    local -n was_set="$3"
    local value="${4-}"

    [[ -n "$value" ]] || die "Missing value for ${option}"


    destination="$value"
    was_set=1
}

parse_args() {
    while (($#)); do
        case "$1" in
			# Case description
			--title)                 set_cli_value "$1" "INPUT[TITLE]" "WAS_SET[TITLE]" "${2-}"; shift ;;
			--description)           set_cli_value "$1" "INPUT[DESCRIPTION]" "WAS_SET[DESCRIPTION]" "${2-}"; shift ;;
			--asset)                 set_cli_value "$1" "INPUT[ASSET]" "WAS_SET[ASSET]" "${2-}"; shift ;;
			--severity)              set_cli_value "$1" "INPUT[SEVERITY]" "WAS_SET[SEVERITY]" "${2-}"; shift ;;
			--site)                  set_cli_value "$1" "INPUT[SITE]" "WAS_SET[SITE]" "${2-}"; shift ;;

			# Ownership and timeline
			--reported-by)           set_cli_value "$1" "INPUT[REPORTED_BY]" "WAS_SET[REPORTED_BY]" "${2-}"; shift ;;
			--owner)                 set_cli_value "$1" "INPUT[OWNER]" "WAS_SET[OWNER]" "${2-}"; shift ;;
			--first-observed)        set_cli_value "$1" "INPUT[FIRST_OBSERVED]" "WAS_SET[FIRST_OBSERVED]" "${2-}"; shift ;;
			--last-observed)         set_cli_value "$1" "INPUT[LAST_OBSERVED]" "WAS_SET[LAST_OBSERVED]" "${2-}"; shift ;;

			# Triage state
			--operational-impact)    set_cli_value "$1" "INPUT[OPERATIONAL_IMPACT]" "WAS_SET[OPERATIONAL_IMPACT]" "${2-}"; shift ;;
			--affected-scope)        set_cli_value "$1" "INPUT[AFFECTED_SCOPE]" "WAS_SET[AFFECTED_SCOPE]" "${2-}"; shift ;;
			--recent-change)         set_cli_value "$1" "INPUT[RECENT_CHANGE]" "WAS_SET[RECENT_CHANGE]" "${2-}"; shift ;;
			--status)                set_cli_value "$1" "INPUT[STATUS]" "WAS_SET[STATUS]" "${2-}"; shift ;;
			--repro-status)          set_cli_value "$1" "INPUT[REPRO_STATUS]" "WAS_SET[REPRO_STATUS]" "${2-}"; shift ;;
			--containment-status)    set_cli_value "$1" "INPUT[CONTAINMENT_STATUS]" "WAS_SET[CONTAINMENT_STATUS]" "${2-}"; shift ;;
			--triage-confidence)     set_cli_value "$1" "INPUT[TRIAGE_CONFIDENCE]" "WAS_SET[TRIAGE_CONFIDENCE]" "${2-}"; shift ;;

			# Case and evidence selection
			--profile)               set_cli_value "$1" "INPUT[PROFILE]" "WAS_SET[PROFILE]" "${2-}"; shift ;;
			--case)                  set_cli_value "$1" "INPUT[CASE]" "WAS_SET[CASE]" "${2-}"; shift ;;
			--file)                  set_cli_value "$1" "INPUT[FILE]" "WAS_SET[FILE]" "${2-}"; shift ;;
			--type)                  set_cli_value "$1" "INPUT[TYPE]" "WAS_SET[TYPE]" "${2-}"; shift ;;
			--output-dir)            set_cli_value "$1" "INPUT[OUTPUT_DIR]" "WAS_SET[OUTPUT_DIR]" "${2-}"; shift ;;

			# Execution behavior
			--apply)               SCRIPT[APPLY]=1 ;;
			--no-load-run)		   SCRIPT[APPLY]=0 ;;
			--force)               SCRIPT[FORCE]=1 ;;
			-v|--verbose)          SCRIPT[VERBOSE]=1 ;;
			--self-test)           SCRIPT[SELF_TEST]=1 ;;
			--version)             printf '%s\n' "$VERSION"; exit 0 ;;
			-h|--help)             usage; exit 0 ;;

			# Commands
			new)                   COMMANDS[NEW]=1;     debug "Option 'new' selected" ;;
			add)                   COMMANDS[ADD]=1;     debug "Option 'add' selected" ;;
			collect)               COMMANDS[COLLECT]=1; debug "Option 'collect' selected" ;;
			verify)                COMMANDS[VERIFY]=1;  debug "Option 'verify' selected" ;;
			bundle)                COMMANDS[BUNDLE]=1;  debug "Option 'bundle' selected" ;;

			*)                     die "Unknown argument: $1" ;;
		esac
        shift
    done

	if (( WAS_SET[TITLE] && !WAS_SET[CASE] )); then
		INPUT[CASE]="${CASE_PREFIX}_${RUN_ID}_${INPUT[TITLE]}"
	elif (( !WAS_SET[TITLE] && WAS_SET[CASE] )); then
		debug "Case-ID: ${INPUT[CASE]}"
	elif (( WAS_SET[TITLE] && WAS_SET[CASE] )); then
		debug "Please set either 'new --title' or 'add --case, not both"
	fi
}

validate_config() {

	debug "running validate_config..."

	if (( COMMANDS[NEW] )); then
		(( WAS_SET[TITLE] )) || die "Input --title required"
		(( WAS_SET[DESCRIPTION] )) || die "Input --description required"
		(( WAS_SET[SEVERITY] )) || die "Input --severity required"
		(( WAS_SET[ASSET] )) || warn "Input --asset missing - using default"
	fi

	if (( COMMANDS[ADD] )); then
		(( WAS_SET[CASE] )) || die "Input --case required"
		[[ -e "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}" ]] || die "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]} does not exist"

	fi



}

# endregion

# =============================================================================
# region S8. Workflow
# =============================================================================

run_workflow() {
    info "Starting workflow"
    info "Run ID: $RUN_ID"
    ensure_dir "${INPUT[OUTPUT_DIR]}/logs"
    ensure_dir "${INPUT[OUTPUT_DIR]}/artifacts"

    make_run_manifest "${INPUT[OUTPUT_DIR]}/logs/run_manifest_${RUN_ID}.txt"

    if (( COMMANDS[NEW] )); then
        ensure_dir "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}"
        ensure_dir "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/manifest"

        make_case_manifest "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/manifest/case_manifest.txt"
        environment_check "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/manifest/environment.txt"
		software_check "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/manifest/software_versions.txt"
 		verify_checksums  "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/manifest/checksums.sha256"

        ensure_dir "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/evidence"
        ensure_dir "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/evidence/raw"
        ensure_dir "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/evidence/photos"
        ensure_dir "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/evidence/logs"
        ensure_dir "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/evidence/operator_notes"

        ensure_dir "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/derived"
        ensure_dir "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/derived/timelines"
        ensure_dir "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/derived/extracts"
        ensure_dir "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/derived/figures"

        ensure_dir "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/commands"
        write_file "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/commands/collection.log" "test collection.log"
        write_file "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/commands/replay.sh" "test replay.sh"

        ensure_dir "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/reports"
        initial_triage "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/reports/initial_triage.md"
        write_file "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/reports/handoff.md" "test handoff.md"
    fi

    if (( COMMANDS[ADD] )); then

        assert_dir_exists "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}"
		assert_file_exists "${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}/manifest/case_manifest.txt"

		debug "Adding ${INPUT[TYPE]} file: ${INPUT[FILE]} to ${INPUT[OUTPUT_DIR]}/${INPUT[CASE]}"

		if [[ -f "${INPUT[FILE]}" && -e "${INPUT[FILE]}" ]]; then

			case "${INPUT[TYPE]}" in
				raw) ;;
				photo)  ;;
				log)  ;;
				note) ;;
				*) warn "Unknown file type. Available: 'raw','photo','log','note'" ;;
			esac
		fi


    fi

    if (( COMMANDS[COLLECT] )); then
        debug "Collect = ${COMMANDS[COLLECT]}"
    fi

    if (( COMMANDS[VERIFY] )); then
        debug "Verify = ${COMMANDS[VERIFY]}"
    fi

    if (( COMMANDS[BUNDLE] )); then
        debug "${COMMANDS[BUNDLE]}"
    fi

    write_summary "${INPUT[OUTPUT_DIR]}/logs/summary_${RUN_ID}.txt" "ok"
    log "ghostcase workflow complete"
}

run_self_test() {
    local tmp_dir old_apply old_output
    tmp_dir="$(mktemp -d)"
    info "Self-test temp dir: $tmp_dir"
    old_apply="${SCRIPT[APPLY]}"
    old_output="${INPUT[OUTPUT_DIR]}"
    SCRIPT[APPLY]=1
    INPUT[OUTPUT_DIR]="$tmp_dir/output"
    INPUT[PROFILE]="${INPUT[PROFILE]:-default}"

	info "Output Directory: ${INPUT[OUTPUT_DIR]}"
    info "Input Path: ${INPUT[PROFILE]}"

	validate_config
    run_workflow
    assert_file_exists "${INPUT[OUTPUT_DIR]}/logs/run_manifest_${RUN_ID}.txt"
    assert_file_exists "${INPUT[OUTPUT_DIR]}/logs/summary_${RUN_ID}.txt"

	if (( SCRIPT[VERBOSE] )); then
        debug "First 5 lines run_manifest:";
        head -n 5 "${INPUT[OUTPUT_DIR]}/logs/run_manifest_${RUN_ID}.txt"
        debug "First 5 lines summary:"
        head -n 5 "${INPUT[OUTPUT_DIR]}/logs/summary_${RUN_ID}.txt"
    fi

	SCRIPT[APPLY]="$old_apply"
    INPUT[OUTPUT_DIR]="$old_output"

    #rm -rf "$tmp_dir"
    log "Self-test passed"
}

# endregion

# =============================================================================
# region S9. Main
# =============================================================================

main() {

    install_runtime

    parse_args "$@"

    if (( SCRIPT[SELF_TEST] )); then
        run_self_test
    else
        validate_config
        run_workflow
    fi
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi

#endregion
