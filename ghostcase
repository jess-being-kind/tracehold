#!/usr/bin/env bash
# =============================================================================
# region script open
# ghostcase.sh
#
# A Bash tool that turns an ambiguous field problem into a complete, timestamped, integrity-checked case file.
#
# Pattern:
#   parse_args ->   self-test       -> run_workflow
#                   validate_config -> run_workflow
#
# Ensures:
# - the right evidence was captured before it disappeared;
# - timestamps and configuration are preserved;
# - everyone is discussing the same vehicle, software version, site, and event;
# - logs can be handed to another engineer without a 30-minute explanation;
# - the original evidence remains distinguishable from processed output;
# - the eventual fix can be connected back to the original symptom.
# endregion

